// Public schema — shared across all tenants
// Tenants, Users, Subscriptions, Invoices

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

// ─── Tenants ───────────────────────────────────────────────────────────────

model Tenant {
  id          String       @id @default(uuid())
  slug        String       @unique
  name        String
  logoUrl     String?
  domain      String?      @unique
  plan        Plan         @default(FREE)
  status      TenantStatus @default(TRIAL)
  trialEndsAt DateTime
  settings    Json         @default("{}")

  maxSkus          Int @default(100)
  maxUsers         Int @default(2)
  maxMonthlyOrders Int @default(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        TenantUser[]
  subscription Subscription?
  invoices     Invoice[]

  @@schema("public")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants TenantUser[]

  @@schema("public")
}

model TenantUser {
  id        String     @id @default(uuid())
  tenantId  String
  userId    String
  role      TenantRole
  isActive  Boolean    @default(true)
  invitedAt DateTime   @default(now())
  joinedAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@schema("public")
}

model Subscription {
  id                   String    @id @default(uuid())
  tenantId             String    @unique
  plan                 Plan
  status               SubStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean   @default(false)
  paymeSubscriptionId  String?
  stripeSubscriptionId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@schema("public")
}

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  subscriptionId String?
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("UZS")
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime
  paidAt         DateTime?
  paymentMethod  String?
  transactionId  String?
  items          Json          @default("[]")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@schema("public")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actorEmail String
  action     String
  targetType String
  targetId   String?
  metadata   Json     @default("{}")
  ip         String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@schema("public")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE

  @@schema("public")
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED

  @@schema("public")
}

enum TenantRole {
  OWNER
  ADMIN
  MANAGER
  CASHIER

  @@schema("public")
}

enum SubStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED

  @@schema("public")
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID

  @@schema("public")
}
